{
  "version": "2.0.0",
  "description": "Portable dynamic agent pool for multi-agent orchestration",
  "roles": [
    {
      "id": "os-operator",
      "name": "OS Operator",
      "purpose": "Operate native OS applications, system settings, window management, and native software functions.",
      "triggerCapabilities": ["os-operation", "app-control", "system-settings"],
      "skills": ["exec", "nodes", "canvas"],
      "deny": ["web_search", "web_fetch", "browser"],
      "memory": {
        "scope": "os-context",
        "items": ["active_window", "installed_apps", "screen_coordinates"]
      },
      "lifecycle": "ephemeral"
    },
    {
      "id": "supervisor",
      "name": "Supervisor",
      "purpose": "Analyze tasks, choose roles, coordinate execution, recover results",
      "triggerCapabilities": ["planning", "coordination", "monitoring"],
      "skills": ["read", "write", "sessions_list", "sessions_history", "sessions_send", "subagents"],
      "deny": ["gateway.*", "cron.*", "plugins.*", "exec"],
      "memory": {
        "scope": "task-state",
        "items": ["execution_plan", "agent_roster", "dependency_graph", "result_summary"]
      },
      "lifecycle": "persistent"
    }
  ]
}
